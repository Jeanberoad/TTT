<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="pragma" content="no-cache" />
    <meta http-equiv="expires" content="-1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WiFi De Tsararano - Connexion</title>
    <link rel="stylesheet" href="css/style.css">
    <script src="theme.js"></script>
</head>
<body>

    $(if chap-id)
    <form name="sendin" action="$(link-login-only)" method="post" style="display:none">
        <input type="hidden" name="username" />
        <input type="hidden" name="password" />
        <input type="hidden" name="dst" value="$(link-orig)" />
        <input type="hidden" name="popup" value="true" />
    </form>

    <script src="/md5.js"></script>
    <script>
        function doLogin() {
            document.sendin.username.value = document.login.username.value;
            document.sendin.password.value = hexMD5('$(chap-id)' + document.login.password.value + '$(chap-challenge)');
            document.sendin.submit();
            return false;
        }
    </script>
    $(endif)

    <div class="login-card">
        <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Changer de thème" title="Changer de thème">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
        </button>
    
        <div class="header">
            <h1>WiFi De Tsararano</h1>
            <p>à votre service</p>
        </div>

        $(if error)
        <div class="error-msg">
            $(error)
        </div>
        $(endif)

        $(if error == "")
            $(if trial == 'yes')
            <div class="error-msg" style="background: rgba(0, 206, 209, 0.1); color: var(--accent-secondary); border-color: rgba(0, 206, 209, 0.2);">
                Essai gratuit disponible, <a href="$(link-login-only)?dst=$(link-orig-esc)&amp;username=T-$(mac-esc)" class="trial-link">cliquez ici</a>.
            </div>
            $(endif)
        $(endif)

        <form name="login" action="$(link-login-only)" method="post" $(if chap-id) onSubmit="return doLogin()" $(endif)>
            <input type="hidden" name="dst" value="$(link-orig)" />
            <input type="hidden" name="popup" value="true" />

            <div class="input-group">
                <input name="username" type="text" value="$(username)" placeholder="Nom d'utilisateur" required autocomplete="username" />
            </div>

                        <div class="input-group password-group">
                          <input id="password-input" name="password" type="password" placeholder="Mot de passe" required autocomplete="current-password" />
                          <button type="button" class="toggle-password" id="toggle-password"
                                          aria-label="Afficher ou masquer le mot de passe" aria-pressed="false">
                                <svg class="eye-open" viewBox="0 0 24 24" aria-hidden="true">
                                  <path d="M12 5c-5.5 0-9.5 5.2-10 6.7.5 1.5 4.5 6.3 10 6.3s9.5-4.8 10-6.3C21.5 10.2 17.5 5 12 5zm0 10a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
                                </svg>
                                <svg class="eye-closed" viewBox="0 0 24 24" aria-hidden="true">
                                  <path d="M2 4.3 3.3 3 21 20.7 19.7 22l-3-3c-1.4.6-3 .9-4.7.9-5.5 0-9.5-4.8-10-6.3.2-.6.9-1.8 2-3.1L2 4.3zM12 7c1.6 0 3.1.3 4.4 1l-1.7 1.7A3 3 0 0 0 10.7 13L8.9 14.8C8.3 14 8 13 8 12a4 4 0 0 1 4-4zm10 5c-.3.9-1.6 2.9-3.7 4.4l-2-2c.5-.7.7-1.5.7-2.4 0-.5-.1-1-.3-1.5l3.1-3.1c1.2 1.3 1.9 2.5 2.2 3.2z"/>
                                </svg>
                          </button>
                        </div>

            <button type="submit" class="btn-submit">Se connecter</button>
        </form>

        <button type="button" class="btn-qr" id="scan-btn">
            <svg class="qr-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 3h6v6H3V3zm2 2v2h2V5H5zm8-2h6v6h-6V3zm2 2v2h2V5h-2zM3 15h6v6H3v-6zm2 2v2h2v-2H5zm10 0h2v2h-2v-2zm2-2h2v2h-2v-2zm0 4h2v2h-2v-2zm2-2h2v2h-2v-2zm0-4h2v2h-2v-2zm-8-2h2v2h-2v-2zm2 2h2v2h-2v-2zm2-2h2v2h-2v-2zm0 2h2v2h-2v-2z"/></svg>
            Scanner QR Code
        </button>

        <div class="copy-container" id="copy-section">
            <p class="copy-info">Copiez le lien puis ouvrez-le dans votre navigateur.</p>
            <button type="button" class="btn-copy" id="copy-btn">Copier le lien</button>
            <input type="text" id="fallback-url-input" readonly>
        </div>

        <div id="scanner-error" class="error-msg" style="display:none; margin-top:15px;"></div>

        <div id="reader"></div>

        <p class="footer-text">By OZ</p>
    </div>

    <script src="html5-qrcode.min.js"></script>
    <script>
        // Optional configuration:
        // - You can define `window.SCAN_URL = "https://example.com/login";` before this script
        //   to control what "Copier le lien" copies.
        document.addEventListener('DOMContentLoaded', () => {
            const scanBtn = document.getElementById('scan-btn');
            const reader = document.getElementById('reader');
            const copyBtn = document.getElementById('copy-btn');
            const copySection = document.getElementById('copy-section');
            const scannerError = document.getElementById('scanner-error');
            const fallbackInput = document.getElementById('fallback-url-input');
            const usernameInput = document.querySelector('form[name="login"] input[name="username"][type="text"]');
                        const passwordInput = document.getElementById('password-input');
                          const togglePasswordBtn = document.getElementById('toggle-password');

                          if (togglePasswordBtn && passwordInput) {
                                togglePasswordBtn.addEventListener('click', (e) => {
                                  e.preventDefault();

                                  const show = passwordInput.type === 'password';
                                  passwordInput.type = show ? 'text' : 'password';
                                  togglePasswordBtn.classList.toggle('is-visible', show);
                                  togglePasswordBtn.setAttribute('aria-pressed', String(show));

                                  passwordInput.focus();
                                  const len = passwordInput.value.length;
                                  passwordInput.setSelectionRange(len, len);
                                });
                          }

            // Avoid focusing the username field on page load (keeps the screen clean until user interaction)
            setTimeout(() => {
                const active = document.activeElement;
                if (active && active.tagName === 'INPUT') {
                    active.blur();
                }
            }, 0);

            const scanBtnIcon = (scanBtn && scanBtn.querySelector('svg')) ? scanBtn.querySelector('svg').outerHTML : '';
            const setScanBtnLabel = (label) => {
                if (!scanBtn) return;
                scanBtn.innerHTML = scanBtnIcon ? (scanBtnIcon + ' ' + label) : label;
            };

            const DEFAULT_SCAN_URL = window.location.href.split('#')[0];
            const SCAN_URL = (typeof window.SCAN_URL === 'string' && window.SCAN_URL.trim())
                ? window.SCAN_URL.trim()
                : DEFAULT_SCAN_URL;

            const START_TIMEOUT_MS = 6000;

            let html5QrCode = null;
            let isStarting = false;
            let startTimeoutId = null;

            function clearStartTimeout() {
                if (startTimeoutId) {
                    clearTimeout(startTimeoutId);
                    startTimeoutId = null;
                }
            }

            function showError(msg) {
                scannerError.textContent = msg;
                scannerError.style.display = 'block';
                copySection.style.display = 'flex';
                // Provide the URL in the fallback field if clipboard permissions fail
                fallbackInput.value = SCAN_URL;
            }

            function hideError() {
                scannerError.style.display = 'none';
                copySection.style.display = 'none';
            }

            function resetScannerUI() {
                reader.style.display = 'none';
                setScanBtnLabel('Scanner QR Code');
            }

            async function safeStopQr() {
                clearStartTimeout();
                isStarting = false;

                if (!html5QrCode) return;
                try {
                    await html5QrCode.stop();
                } catch (_) {
                    // ignore
                }
            }

            function onScanSuccess(decodedText) {
                if (decodedText && decodedText.startsWith('http')) {
                    window.location.href = decodedText;
                } else if (decodedText) {
                    const parts = decodedText.split(':');
                    if (parts.length >= 1) {
                        document.login.username.value = parts[0];
                        if (parts.length >= 2) {
                            document.login.password.value = parts[1];
                        }
                    }
                }
                stopScanner();
            }

            async function startScanner() {
                hideError();

                // Security / capability checks
                if (!window.isSecureContext) {
                    showError("Le scan caméra nécessite une connexion sécurisée. Utilisez “Copier le lien” puis ouvrez-le dans votre navigateur.");
                    resetScannerUI();
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    showError("L'accès à la caméra n'est pas supporté ici. Utilisez “Copier le lien” puis ouvrez-le dans votre navigateur.");
                    resetScannerUI();
                    return;
                }

                reader.style.display = 'block';
                isStarting = true;
                setScanBtnLabel('Démarrage…');

                try {
                    // Probe camera access first, then STOP the test stream to avoid locking the camera
                    const probeStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
                    probeStream.getTracks().forEach(t => t.stop());

                    if (!html5QrCode) {
                        html5QrCode = new Html5Qrcode("reader");
                    }

                    const config = { fps: 10, qrbox: { width: 250, height: 250 } };

                    const startPromise = html5QrCode.start(
                        { facingMode: "environment" },
                        config,
                        onScanSuccess
                    );

                    const timeoutPromise = new Promise((_, reject) => {
                        startTimeoutId = setTimeout(() => {
                            const e = new Error('StartTimeout');
                            e.name = 'StartTimeout';
                            reject(e);
                        }, START_TIMEOUT_MS);
                    });

                    await Promise.race([startPromise, timeoutPromise]);

                    clearStartTimeout();
                    isStarting = false;
                    setScanBtnLabel('Annuler le scan');
                } catch (err) {
                    clearStartTimeout();
                    isStarting = false;

                    let errorMsg = "Erreur d'accès à la caméra.";

                    if (err && err.name === 'StartTimeout') {
                        errorMsg = "Le démarrage du scanner prend trop de temps. Utilisez “Copier le lien” puis ouvrez-le dans votre navigateur.";
                    } else if (err && err.name === 'NotAllowedError') {
                        errorMsg = "Accès à la caméra refusé ou indisponible ici. Utilisez “Copier le lien” puis ouvrez-le dans votre navigateur.";
                    } else if (err && err.name === 'NotFoundError') {
                        errorMsg = "Aucune caméra détectée.";
                    } else if (err && err.name === 'NotReadableError') {
                        errorMsg = "Caméra occupée par une autre application.";
                    } else if (err && err.name === 'OverconstrainedError') {
                        errorMsg = "Caméra arrière indisponible, essayez une autre caméra.";
                    }

                    showError(errorMsg);
                    await safeStopQr();
                    resetScannerUI();
                }
            }

            async function stopScanner() {
                await safeStopQr();
                resetScannerUI();
            }

            function copyToClipboard() {
                const url = SCAN_URL;

                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(url).then(() => {
                        const originalText = copyBtn.textContent;
                        copyBtn.textContent = 'Lien copié !';
                        setTimeout(() => copyBtn.textContent = originalText, 2000);
                    }).catch(() => fallbackCopy(url));
                } else {
                    fallbackCopy(url);
                }
            }

            function fallbackCopy(url) {
                fallbackInput.value = url;
                fallbackInput.style.display = 'block';
                fallbackInput.select();
                try {
                    document.execCommand('copy');
                    const originalText = copyBtn.textContent;
                    copyBtn.textContent = 'Lien copié !';
                    setTimeout(() => copyBtn.textContent = originalText, 2000);
                } catch (_) {
                    copyBtn.textContent = 'Sélectionnez le lien ci-dessous';
                }
            }

            function setPrefix(prefix) {
                if (!usernameInput) return;
                usernameInput.value = prefix;
                usernameInput.focus();
                const len = usernameInput.value.length;
                usernameInput.setSelectionRange(len, len);
            }

            // Scanner button
            if (scanBtn) {
                scanBtn.addEventListener('click', () => {
                    // Allow cancel even during "starting"
                    if (reader.style.display === 'block') {
                        stopScanner();
                    } else {
                        startScanner();
                    }
                });
            }

            // Copy link button
            if (copyBtn) {
                copyBtn.addEventListener('click', copyToClipboard);
            }

            // Tariff selection (robust via data-prefix)
            document.querySelectorAll('.price-card[data-prefix]').forEach(card => {
                card.addEventListener('click', () => {
                    const prefix = card.getAttribute('data-prefix') || '';
                    if (prefix) setPrefix(prefix);
                });
            });
        });
    </script>

    <div class="price-section">
        <h2 class="price-title">Nos Tarifs</h2>
                
                
        <div class="price-card" data-prefix="AB-">
            <span class="price-time">1 mois</span>
            <span class="price-amount">30 000 Ar</span>
        </div>
        
                <div class="price-card" data-prefix="24h-">
            <span class="price-time">24h</span>
            <span class="price-amount">3 000 Ar</span>
        </div>
                
        <div class="price-card" data-prefix="1h30m-0">
            <span class="price-time">1h 30m</span>
            <span class="price-amount">1 000 Ar</span>
        </div>

        <div class="price-card" data-prefix="30m-0">
            <span class="price-time">30m</span>
            <span class="price-amount">500 Ar</span>
        </div>
    </div>

    <div class="tutorial-spacer"></div>

    <section class="tutorial-section">
        <div class="tutorial-content">
            <h2 class="tutorial-title">Comment ça marche ?</h2>
            <p class="tutorial-subtitle">Regardez ce court tutoriel pour vous connecter facilement</p>
            
            <div class="phone-frame">
                <div class="phone-notch"></div>
                <div class="phone-screen">
                    <video 
                        id="tutorial-video" 
                        class="phone-video"
                        width="100%" 
                        height="100%" 
                        autoplay
                        playsinline
                        muted
                        loop
                        controls
                        style="cursor: pointer; -webkit-user-select: none; user-select: none;"
                    >
                        <source src="./tutorial.mp4" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                </div>
                <div class="phone-bottom"></div>
            </div>
        </div>
    </section>

    <script>
        // Radiant effect color animation with smooth transitions
        const radiantColors = [
            { primary: '#8a2be2', secondary: '#00ced1', rgb1: '138, 43, 226', rgb2: '0, 206, 209' },
            { primary: '#ff4f7b', secondary: '#ff9b2f', rgb1: '255, 79, 123', rgb2: '255, 155, 47' },
            { primary: '#2b6de2', secondary: '#38d6ff', rgb1: '43, 109, 226', rgb2: '56, 214, 255' },
            { primary: '#ff8a00', secondary: '#00c2ff', rgb1: '255, 138, 0', rgb2: '0, 194, 255' }
        ];
        
        let colorIndex = 0;
        function rotateRadiantColors() {
            colorIndex = (colorIndex + 1) % radiantColors.length;
            const colors = radiantColors[colorIndex];
            const style = document.documentElement.style;
            style.setProperty('--radiant-primary', colors.primary);
            style.setProperty('--radiant-secondary', colors.secondary);
            style.setProperty('--radiant-primary-rgb', colors.rgb1);
            style.setProperty('--radiant-secondary-rgb', colors.rgb2);
        }
        
        setInterval(rotateRadiantColors, 2000);
        rotateRadiantColors();

        // Scroll-based background fade effect - more progressive and smooth
        let lastScrollY = 0;
        const maxScroll = window.innerHeight * 4.5;
        
        window.addEventListener('scroll', () => {
            const scrollY = window.scrollY;
            lastScrollY = scrollY;
            
            // More gradual fade using cubic easing for smoother transition
            const ratio = Math.min(scrollY / maxScroll, 1);
            // Apply cubic easing: 3t² - 2t³ for smoother acceleration
            const eased = ratio < 0.5 
                ? 2 * ratio * ratio 
                : 1 - Math.pow(-2 * ratio + 2, 2) / 2;
            document.documentElement.style.setProperty('--scroll-bg-opacity', eased);
        }, { passive: true });

        // Auto-play video on scroll
        document.addEventListener('DOMContentLoaded', () => {
            const video = document.getElementById('tutorial-video');
            if (!video) return;

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        // Auto-play video with fallback for Safari/iOS
                        const playPromise = video.play();
                        if (playPromise !== undefined) {
                            playPromise
                                .then(() => {
                                    video.classList.add('video-playing');
                                })
                                .catch(err => {
                                    console.log('Autoplay prevented, user interaction required:', err);
                                    // Video will require user interaction
                                });
                        }
                    } else {
                        video.pause();
                        video.classList.remove('video-playing');
                    }
                });
            }, {
                threshold: 0.3
            });

            observer.observe(video);
            
            // Allow manual play on click/tap for iOS compatibility (if autoplay fails)
            video.addEventListener('click', (e) => {
                e.stopPropagation();
                if (video.paused) {
                    const playPromise = video.play();
                    if (playPromise !== undefined) {
                        playPromise
                            .then(() => {
                                video.classList.add('video-playing');
                            })
                            .catch(err => console.log('Manual play error:', err));
                    }
                } else {
                    video.pause();
                    video.classList.remove('video-playing');
                }
            }, false);
        });
    </script>

</body>
</html>
